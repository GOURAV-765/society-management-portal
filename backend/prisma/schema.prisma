datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Tenant (Society) Isolation
model Society {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String?
  city        String?
  state       String?
  zipCode     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  roles       Role[]
  members     Member[]
  visitors    Visitor[]
  complaints  Complaint[]
  finance     Transaction[]
  bookings    Booking[]
  facilities  Facility[]
  notices     Notice[]
  awardRules  AwardRule[]
  awardNominations AwardNomination[]
  projects         Project[]
  events           Event[]
  contributions    ContributionActivity[]
}

// 2. User Authentication & Session
model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  email        String    @unique
  passwordHash String?
  clerkId      String?   // Optional fallback for Clerk migration
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  societyId    String    @db.ObjectId
  society      Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  roleId       String    @db.ObjectId
  role         Role      @relation(fields: [roleId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  member       Member?
  sessions     Session[]
  complaints   Complaint[] // Created complaints
  assignedTasks ComplaintTask[] // Assigned complaints (for staff)
  auditLogs    AuditLog[]
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique // Refresh token hash
  expiresAt    DateTime
  deviceInfo   String?
  createdAt    DateTime @default(now())
}

// 3. RBAC Schema
model Role {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  name        String           // Super Admin, Society Admin, Resident, Security, etc.
  description String?
  societyId   String?          @db.ObjectId // Null if global system role, otherwise tenant-scoped
  society     Society?         @relation(fields: [societyId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       User[]

  @@unique([name, societyId])
}

model Permission {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  name        String           @unique // e.g. "member:read", "complaint:create"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  roleId       String     @db.ObjectId
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @db.ObjectId
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// 4. Member Profile Details
model Member {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @unique @db.ObjectId
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  societyId    String    @db.ObjectId
  society      Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  unitNumber   String    // Flat / Block details
  phone        String?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  awardNominations AwardNomination[]
  bio          String?
  skills       String?   // Comma-separated or JSON
  githubUrl    String?
  linkedinUrl  String?
  resumeUrl    String?
  portfolioUrl String?
  techStack    String?
  projectMembers   ProjectMember[]
  assignedTasks    ProjectTask[]
  eventRegistrations EventRegistration[]
  contributions    ContributionActivity[]
}

// 5. Visitor Management
model Visitor {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  societyId   String   @db.ObjectId
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  purpose     String
  otpCode     String?  // Secure entry verification OTP
  qrCodeUrl   String?  // Direct access scan link
  status      String   @default("PENDING") // PENDING, APPROVED, DENIED, COMPLETED
  checkIn     DateTime?
  checkOut    DateTime?
  createdAt   DateTime @default(now())
}

// 6. Complaints & AI Processing
model Complaint {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  societyId    String           @db.ObjectId
  society      Society          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  creatorId    String           @db.ObjectId
  creator      User             @relation(fields: [creatorId], references: [id])
  title        String
  description  String
  category     String           // AI Categorized: PLUMBING, ELECTRICAL, SECURITY, etc.
  priority     String           @default("MEDIUM") // AI Classified: LOW, MEDIUM, HIGH, URGENT
  status       String           @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  tasks        ComplaintTask[]
  attachments  Attachment[]
}

model Attachment {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  url          String
  complaintId  String    @db.ObjectId
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
}

model ComplaintTask {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  complaintId String    @db.ObjectId
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  staffId     String    @db.ObjectId
  staff       User      @relation(fields: [staffId], references: [id])
  notes       String?
  assignedAt  DateTime  @default(now())
  resolvedAt  DateTime?
}

// 7. Treasury & Financial Transactions
model Transaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  societyId   String   @db.ObjectId
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  amount      Float
  type        String   // INCOME, EXPENSE
  category    String   // Maintenance Dues, Facility Booking, Event Fee, Vendor Payment
  description String
  invoiceUrl  String?
  createdAt   DateTime @default(now())
}

// 8. Facilities & Amenity Bookings
model Facility {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  societyId   String    @db.ObjectId
  society     Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  costPerHour Float     @default(0.0)
  bookings    Booking[]
}

model Booking {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  societyId   String   @db.ObjectId
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  facilityId  String   @db.ObjectId
  facility    Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  status      String   @default("CONFIRMED") // CONFIRMED, CANCELLED
  createdAt   DateTime @default(now())
}

// 9. Notices & Broadcasts
model Notice {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  societyId   String   @db.ObjectId
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title       String
  content     String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// 10. Audit Logs
model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g. "USER_LOGIN", "COMPLAINT_RESOLVED"
  details   String   // JSON string of changes
  ipAddress String?
  createdAt DateTime @default(now())
}

// 11. Awards & Recognition Module
model AwardRule {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  societyId    String            @db.ObjectId
  society      Society           @relation(fields: [societyId], references: [id], onDelete: Cascade)
  awardType    String            // MEMBER_OF_MONTH, BEST_VOLUNTEER, BEST_DEVELOPER, BEST_DESIGNER, etc.
  name         String            // Display name e.g., "Best Developer of the Month"
  description  String?
  minEvents    Int               @default(0)
  minVolHours  Float             @default(0.0)
  minTasks     Int               @default(0)
  weightEvents Float             @default(1.0)
  weightVolHrs Float             @default(1.0)
  weightTasks  Float             @default(1.0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  nominations  AwardNomination[]

  @@unique([societyId, awardType])
}

model AwardNomination {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  societyId   String   @db.ObjectId
  society     Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  awardRuleId String   @db.ObjectId
  awardRule   AwardRule @relation(fields: [awardRuleId], references: [id], onDelete: Cascade)
  memberId    String   @db.ObjectId
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  period      String   // e.g. "2026-07"
  score       Float
  status      String   @default("NOMINATED") // NOMINATED, APPROVED, REJECTED
  reason      String?  // Score breakdown or manual override justification
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  winner      AwardWinner?

  @@unique([awardRuleId, memberId, period])
}

model AwardWinner {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  nominationId   String          @unique @db.ObjectId
  nomination     AwardNomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  certificateUrl String?
  qrCodeUrl      String?
  badgeUrl       String?
  shareCardUrl   String?
  createdAt      DateTime        @default(now())
}

// 12. Project Collaboration Module
model Project {
  id           String             @id @default(auto()) @map("_id") @db.ObjectId
  societyId    String             @db.ObjectId
  society      Society            @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title        String
  description  String
  githubUrl    String?
  demoUrl      String?
  techStack    String             // Comma-separated or JSON list
  status       String             @default("IDEATION") // IDEATION, DEVELOPMENT, COMPLETED, ARCHIVED
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  members      ProjectMember[]
  milestones   ProjectMilestone[]
  tasks        ProjectTask[]
}

model ProjectMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  memberId  String   @db.ObjectId
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role      String   // OWNER, LEAD, DEVELOPER, DESIGNER, PR
  joinedAt  DateTime @default(now())

  @@unique([projectId, memberId])
}

model ProjectMilestone {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String   @db.ObjectId
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ProjectTask {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  projectId   String    @db.ObjectId
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("TODO") // TODO, IN_PROGRESS, IN_REVIEW, DONE
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate     DateTime?
  assigneeId  String?   @db.ObjectId
  assignee    Member?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 13. Event Management Module
model Event {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  societyId    String              @db.ObjectId
  society      Society             @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title        String
  description  String
  bannerUrl    String?
  startDate    DateTime
  endDate      DateTime
  location     String
  budget       Float               @default(0.0)
  speakerInfo  String?             // JSON or text list of speakers
  sponsorInfo  String?             // JSON or text list of sponsors
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  registrations EventRegistration[]
}

model EventRegistration {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String    @db.ObjectId
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId     String    @db.ObjectId
  member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  checkInCode  String    @unique
  isCheckedIn  Boolean   @default(false)
  checkInTime  DateTime?
  rating       Int?
  feedback     String?
  createdAt    DateTime  @default(now())

  @@unique([eventId, memberId])
}

// 14. Contribution Logs
model ContributionActivity {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  societyId    String   @db.ObjectId
  society      Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  memberId     String   @db.ObjectId
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  activityType String   // VOLUNTEER, EVENT_ORGANIZED, WORKSHOP, TECHNICAL, DESIGN, PR, CONTENT
  description  String
  scorePoints  Float
  date         DateTime @default(now())
}
